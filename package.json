    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "axios": "^1.9.0",
    "axios-cache-interceptor": "^1.8.0",
    "fireworks-js": "^2.10.8",
    "pokenode-ts": "^1.20.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@tailwindcss/postcss": "^4.1.6",
    "daisyui": "^5.0.35",
    "postcss": "^8.5.3",
